# llm-tasks 配置示例
# 复制为 .env 后填写实际值
# cp .env.example .env

# ===== Provider 选择 =====
# 可选值：mmx-cli | openai | openrouter | azure | google | dashscope | zai | minimax
LLM_PROVIDER=mmx-cli
SETUP_COMPLETED=false

# ===== mmx-cli（MiniMax CLI）=====
# 必填：MMX Token Plan Key（不是普通 MiniMax API Key）
# llm-tasks 会把 MMX_TOKEN_PLAN_KEY 传给 mmx-cli 使用
# 安装：npm install -g @minimaxhub/mmx-cli
# 配置：也可以运行 mmx config set-api-key <your-token-plan-key>
# 模型固定为 MiniMax-M2.7，不接受配置
MMX_TOKEN_PLAN_KEY=your-mmx-token-plan-key-here

# ===== OpenAI 兼容 API =====
OPENAI_API_KEY=sk-...
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o

# ===== OpenRouter =====
OPENROUTER_API_KEY=sk-or-...
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=google/gemini-3.1-flash

# ===== Azure OpenAI =====
AZURE_OPENAI_API_KEY=your-azure-key
AZURE_OPENAI_BASE_URL=https://your-resource.openai.azure.com
AZURE_OPENAI_DEPLOYMENT=gpt-4o

# ===== Google AI =====
GOOGLE_API_KEY=your-google-key
GOOGLE_BASE_URL=https://generativelanguage.googleapis.com/v1beta
GOOGLE_MODEL=gemini-2.0-flash

# ===== DashScope（阿里通义）=====
DASHSCOPE_API_KEY=your-dashscope-key
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/api/v1
DASHSCOPE_MODEL=qwen-plus

# ===== Zhipu AI（智谱）=====
ZAI_API_KEY=your-zhipu-key
ZAI_BASE_URL=https://api.z.ai/api/paas/v4
ZAI_MODEL=glm-z1

# ===== MiniMax HTTP API（直接调用，非 CLI）=====
MINIMAX_HTTP_API_KEY=your-key
MINIMAX_HTTP_BASE_URL=https://api.minimaxi.com
MINIMAX_HTTP_MODEL=MiniMax-M2.7

# ===== 通用超时（秒）=====
LLM_TIMEOUT=180
